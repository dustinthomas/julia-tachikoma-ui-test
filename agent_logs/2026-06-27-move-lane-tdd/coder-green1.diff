+            sel = (i == m.move_lane_selected)
+            p = sel ? "▶ " : "  "
+            set_string!(buf, inner.x + 1, y, p * col, sel ? Style(; fg=QCI_CYAN, bold=true) : Style(; fg=QCI_SECONDARY))
+            y += 1
+        end
+        if y < bottom(inner)
+            set_string!(buf, inner.x + 1, y, "[enter] move   [esc] cancel", Style(; fg = QCI_CYAN, dim = true))
+        end
+    end
 end
 
